# Fizzy API credentials (configurar en Coolify > Environment Variables)
FIZZY_TOKEN=your_api_token_here
FIZZY_ACCOUNT=your_account_id_here
FIZZY_API_URL=https://fizzy.soul23.cloud
FIZZY_BOARD=your_board_id_here
# Ejemplo real: 03g6mw4stdj3riyo3excxnzwn

# Server
# Coolify asigna un puerto random automaticamente via PORT.
# No es necesario definir esta variable manualmente en Coolify.
# PORT=3000
